# ─────────────────────────────────────────────────────────────────────────────
# ForgeTrack — Environment Variables Reference
# Copy to .env and fill in values for local dev.
# For production, set these in Render's dashboard (backend) and Vercel (frontend).
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=workout

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: leave blank — uses ./workout.db (SQLite file)
# Production (Turso): fill in both values below
TURSO_DATABASE_URL=
# Format: libsql://<database-name>-<org>.turso.io
# Get it: turso db show <db-name> --url
TURSO_AUTH_TOKEN=
# Get it: turso db tokens create <db-name>

# ── Cloudflare R2 (file uploads) ──────────────────────────────────────────────
# Local dev: leave blank — files saved to ./uploads/
# Production: fill in all R2 values
R2_ACCOUNT_ID=
# Cloudflare dashboard > right sidebar > Account ID
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Create both from: Cloudflare dashboard > R2 > Manage API Tokens
R2_BUCKET_NAME=forgetrack-uploads
R2_PUBLIC_URL=
# Enable public access on bucket, then: https://pub-<hash>.r2.dev
# OR use a custom domain set up in R2 bucket settings

# ── CORS (backend) ────────────────────────────────────────────────────────────
# Local dev: leave blank — localhost origins always allowed
# Production: set to your Vercel app URL (no trailing slash)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Frontend (Vercel env vars) ────────────────────────────────────────────────
# Set this in Vercel dashboard under Settings > Environment Variables
# Local dev: leave blank — Vite proxy handles /api calls
VITE_API_URL=https://your-backend.onrender.com
